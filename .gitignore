# FITS data files — keep raw data out of the repository
*.fits
*.fit
*.fts

# PNG figures generated by --documentation mode are tracked,
# but large data-product figures should not be committed.
# Uncomment the line below if you do NOT want figures tracked:
# figures/

# Python byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribution / packaging
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Editor / OS artefacts
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
